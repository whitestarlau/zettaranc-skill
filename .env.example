# 数据模式: jnb(走Tushare API) 或 websearch(走网络搜索)
DATA_MODE=jnb

# Tushare API 配置
TUSHARE_TOKEN=你的56位token

# Tushare 中转 API 地址（可选，不填则使用 Tushare 官方地址）
# 格式: http://your-proxy-server.com
# TUSHARE_API_URL=
# TUSHARE_VERIFY_TOKEN_URL=

# 数据库配置
# 数据库配置
DATA_DIR=data
DB_PATH=data/stock_data.db

# LLM 配置（意图识别后的回答生成）
# MiniMax（国内，推荐）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1/chat/completions
MINIMAX_MODEL=MiniMax-M2.7
